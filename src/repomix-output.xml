export function ActionCard({
    href,
    primary = false,
    icon,
    title,
    subtitle,
    badge,
    progress,
    primaryBg = "bg-[#1cb0f6]",
    primaryBorderB = "border-[#1899d6]",
    primaryHover = "hover:bg-[#149fdf]",
    primaryText = "text-[#1cb0f6]",
    primaryBgLight = "bg-[#1cb0f6]/10",
