interface ActionCardProps {
    href: string;
    primary?: boolean;
    icon: ReactNode;
    title: string;
    subtitle?: string;
    badge?: ReactNode;
    progress?: {
        value: number;
        label: string;
    };
    primaryBg?: string;
    primaryBorderB?: string;
    primaryHover?: string;
    primaryText?: string;
    primaryBgLight?: string;
    className?: string;
