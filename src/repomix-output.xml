<file path="features/flashcard/games/shared/hooks/useSharedLessonLoader.ts">
/**
 * useSharedLessonLoader Hook
 *
 * @remarks
 * Centralized hook for loading shared lesson data with consistent
 * loading/error states across all shared game modes.
 *
 * Responsibilities:
 * - Fetch shared lesson data
 * - Handle loading states
 * - Handle error states
 * - Provide consistent UI states
 */

import { useSharedLesson } from "@/features/flashcard/core/hooks";

interface UseSharedLessonLoaderResult {
    result: ReturnType<typeof useSharedLesson>["result"];
    status: ReturnType<typeof useSharedLesson>["status"];
    isLoading: boolean;
    isReady: boolean;
    isNotFound: boolean;
}

/**
 * Hook for loading shared lesson data
 *
 * @param shareId - Unique share token
 * @returns Shared lesson data with status flags
 */
export function useSharedLessonLoader(shareId: string): UseSharedLessonLoaderResult {
    const { result, status } = useSharedLesson(shareId);

    return {
        result,
        status,
        isLoading: status === "loading",
        isReady: status === "ready" && !!result,
        isNotFound: status === "not_found" || (status === "ready" && !result),
    };
}
