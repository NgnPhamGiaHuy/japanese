                                        {entry.displayName}
                                        {isMe && (
                                            <span className="ml-1 text-[10px] font-bold opacity-50">
                                                (you)
                                            </span>
                                        )}
                                    </span>
                                </div>

                                <div className="flex shrink-0 items-center gap-2">
                                    {(() => {
