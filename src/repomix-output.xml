    showHandle = true,
    handlePositionClassName = "absolute top-1/2 -left-8 -translate-y-1/2 md:-left-10",
    onDragStart,
    onDragEnd,
}: ReorderItemProps<T>) => {
    const dragControls = useDragControls();

    return (
        <Reorder.Item
            as={as}
            value={value}
            dragListener={false}
            dragControls={dragControls}
            className={className}
            onDragStart={onDragStart}
            onDragEnd={onDragEnd}
        >
            {!disabled && showHandle && (
                <button
                    type="button"
                    onPointerDown={(e) => dragControls.start(e)}
                    className={
                        handleClassName ??
                        `${handlePositionClassName} cursor-pointer opacity-0 transition-all group-hover:opacity-100 hover:scale-110 active:cursor-grabbing`
                    }
                    aria-label="Reorder item"
                >
                    <GripVertical
                        size={handleIconSize}
                        className="text-gray-300 hover:text-gray-500"
                    />
                </button>
            )}
            {children}
        </Reorder.Item>
