/**
 * Shared Match Mode Page — Pure Orchestrator
 *
 * @remarks
 * Responsibilities (ONLY):
 * - Extract route params
 * - Fetch shared lesson data
 * - Handle loading/404 states
 * - Render SharedMatchGame feature root
 *
 * NO business logic, NO game state, NO direct service calls.
 */

"use client";

import { useRouter } from "next/navigation";
import { use } from "react";

import { SharedMatchGame } from "@/features/flashcard/games";
import { useSharedLessonLoader } from "@/features/flashcard/games/shared/hooks";
import { LoadingSpinner, NotFoundScreen } from "@/shared/components/ui";

export default function SharedMatchPage({ params }: { params: Promise<{ shareId: string }> }) {
    const { shareId } = use(params);
    const router = useRouter();
    const { result, isLoading, isReady } = useSharedLessonLoader(shareId);

    // ── Loading State ──────────────────────────────────────────────────────
    if (isLoading) {
        return <LoadingSpinner color="#ce82ff" />;
    }

    // ── 404 Guard ──────────────────────────────────────────────────────────
    if (!isReady || !result) {
        return <NotFoundScreen title="Deck Not Found" onBack={() => router.back()} />;
    }

    // ── Delegate to Feature ────────────────────────────────────────────────
    return <SharedMatchGame shareId={shareId} result={result} />;
}
