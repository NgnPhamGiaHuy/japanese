rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── HELPER FUNCTIONS ───────────────────────────────────────────────────
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getLesson(appId, ownerId, lessonId) {
      return get(/databases/$(database)/documents/artifacts/$(appId)/users/$(ownerId)/lessons/$(lessonId)).data;
    }

    // Returns true when a lesson document allows public (anonymous) read access.
    function isPublicLesson(lessonData) {
      return lessonData.isPublic == true || lessonData.allowLinkAccess == true;
    }

    // ─── CORE DOMAIN RULES ──────────────────────────────────────────────────

    match /artifacts/{appId} {
      
      match /users/{userId} {
        // User profile and progress
        allow read, write: if isOwner(userId);
        
        match /lessons/{lessonId} {
          // Public decks are readable by anyone (including anonymous users).
          // Role-based access still requires authentication.
          allow read: if isPublicLesson(resource.data)
                      || isOwner(userId)
                      || (isSignedIn() && resource.data.roles[request.auth.uid] != null);
          
          allow create: if isOwner(userId);
          
          // Only owner or explicit editor role may mutate lesson metadata.
          allow update: if isOwner(userId)
                        || (isSignedIn() && resource.data.roles[request.auth.uid] == 'editor');
          
          allow delete: if isOwner(userId);

          // Nesting for deep comments (Path from comment.service.ts)
          match /cards/{cardId}/comments/{commentId} {
            allow read: if isOwner(userId)
                        || isPublicLesson(getLesson(appId, userId, lessonId))
                        || (isSignedIn() && getLesson(appId, userId, lessonId).roles[request.auth.uid] != null);
            
            allow create: if isOwner(userId)
                          || (isSignedIn() && getLesson(appId, userId, lessonId).roles[request.auth.uid] in ['owner', 'editor', 'commenter']);
            
            allow update, delete: if isOwner(userId)
                                  || (isSignedIn() && request.auth.uid == resource.data.userId)
                                  || (isSignedIn() && getLesson(appId, userId, lessonId).roles[request.auth.uid] == 'editor');
          }
        }
        
        match /cards/{cardId} {
          // Cards are readable when the parent lesson is public or the viewer has a role.
          // Anonymous reads are allowed when the parent lesson is public.
          allow read: if isOwner(userId)
                      || isPublicLesson(getLesson(appId, userId, resource.data.lessonId))
                      || (isSignedIn() && getLesson(appId, userId, resource.data.lessonId).roles[request.auth.uid] != null);
          
          // Only owner or editor may write cards — never from a shared/anonymous context.
          allow write: if isOwner(userId)
                       || (isSignedIn() && getLesson(appId, userId, resource.data.lessonId).roles[request.auth.uid] == 'editor');
        }

        match /notifications/{notiId} {
          allow read, update, delete: if isOwner(userId);
          allow create: if isSignedIn();
        }
        
        match /sharedProgress/{shareId} {
          // Only the viewer who owns this progress document may read or write it.
          allow read, write: if isOwner(userId);
        }
      }

      // ─── PENDING NOTIFICATIONS (Pre-login invites) ────────────────────────
      
      match /pendingNotifications/{email}/items/{id} {
        // Users can read pending invites sent to their specific email
        allow read, delete: if isSignedIn() && request.auth.token.email.lower() == email.lower();
        // Anyone signed in can send a notification/invite
        allow create: if isSignedIn();
      }
    }

    // ─── COLLECTION GROUP QUERIES ───────────────────────────────────────────

    // Enables discovery of shared decks across the global users collection.
    // Public decks are readable without authentication; role-based access requires auth.
    match /{path=**}/lessons/{lessonId} {
      allow read: if resource.data.isPublic == true
                  || resource.data.allowLinkAccess == true
                  || (isSignedIn() && (
                       resource.data.roles[request.auth.uid] != null ||
                       resource.data.collaborators.hasAny([request.auth.uid])
                     ));
    }
  }
}
